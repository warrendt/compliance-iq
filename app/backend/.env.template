# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Auth: DefaultAzureCredential (local → `az login`; Azure → Managed Identity)
# If your OpenAI resource has disableLocalAuth=false, you can set an API key:
# AZURE_OPENAI_API_KEY=<key>
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1
AZURE_OPENAI_FALLBACK_MODEL=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Azure Cosmos DB ───────────────────────────────────────────────────────────
# Auth: DefaultAzureCredential (same as OpenAI)
COSMOS_DB_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_DB_DATABASE_NAME=compliance-iq-db

# ── Application Insights (optional) ──────────────────────────────────────────
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=https://...

# ── Managed Identity (optional, for user-assigned MI in Azure) ────────────────
# AZURE_CLIENT_ID=<managed-identity-client-id>

# ── Azure AD Authentication (optional) ───────────────────────────────────────
# ENABLE_AUTH=false
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_ID=

# ── App Settings ─────────────────────────────────────────────────────────────
# ENVIRONMENT: development | staging | production
ENVIRONMENT=development
LOG_LEVEL=INFO
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# AI Mapping Settings
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2000
AI_BATCH_SIZE=5

# Data Paths (relative to backend directory)
MCSB_DATA_PATH=../data/mcsb/mcsb_v1_controls.json
POLICY_MAPPINGS_PATH=../data/mcsb/azure_policy_mappings.json
