{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION=swedencentral}"
    },
    "resourceGroupName": {
      "value": "${AZURE_RESOURCE_GROUP=}"
    },
    "namingPrefix": {
      "value": "${AZURE_NAME_PREFIX=}"
    },
    "openAiModelName": {
      "value": "${AZURE_OPENAI_MODEL_NAME=gpt-5.2}"
    },
    "openAiModelVersion": {
      "value": "${AZURE_OPENAI_MODEL_VERSION=2025-12-11}"
    },
    "openAiFallbackModel": {
      "value": "${AZURE_OPENAI_FALLBACK_MODEL=gpt-5.4-mini}"
    },
    "openAiFallbackVersion": {
      "value": "${AZURE_OPENAI_FALLBACK_VERSION=2026-03-17}"
    },
    "devPublicIpAddress": {
      "value": "${DEV_PUBLIC_IP=}"
    },
    "authClientId": {
      "value": "${AUTH_CLIENT_ID=}"
    },
    "authClientSecret": {
      "value": "${AUTH_CLIENT_SECRET=}"
    },
    "authTenantId": {
      "value": "${AUTH_TENANT_ID=}"
    }
  }
}
